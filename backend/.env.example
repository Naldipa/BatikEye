# Copy file ini menjadi .env untuk local development.
# Untuk production, isi variabel ini lewat secret/environment platform deploy.

ENVIRONMENT=development

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_UPLOAD_BUCKET=uploads

MODEL_PATH=./models/model_Newbatik_saved

# Local development:
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://127.0.0.1:5173,http://127.0.0.1:4173

# Production example:
# ENVIRONMENT=production
# CORS_ORIGINS=https://batikeye.example.com

BACKEND_DEBUG=false
